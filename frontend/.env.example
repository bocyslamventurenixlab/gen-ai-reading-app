# Supabase Configuration (Public - Safe to expose in browser)
# VITE_SUPABASE_URL - Your Supabase project URL (public)
# VITE_SUPABASE_ANON_KEY - Supabase anonymous key (protected by Row Level Security)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gateway API Endpoint
VITE_GATEWAY_URL=http://localhost:3001

# Application Environment
VITE_APP_ENV=development