# Supabase Configuration (Server-side - KEEP SECRET)
# SUPABASE_URL - Your Supabase project URL
# SUPABASE_KEY - Supabase service role key (enables Row Level Security enforcement)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# External APIs (Server-side - KEEP SECRET)
# OPENROUTER_API_KEY - API key for OpenRouter AI service
OPENROUTER_API_KEY=your-api-key

# Application Configuration
NODE_ENV=development
PORT=8000
DEBUG=True
